# -------------------------------------------------------------
# ENV VARIABLES FOR CHATFIX BACKEND
# -------------------------------------------------------------

# Puerto donde corre el servidor de la API
PORT=3005

# Cadena de conexión para MongoDB (Local o en Docker)
# Ejemplo local: mongodb://localhost:27017/chatfix
# Ejemplo docker: mongodb://mongo:27017/chatfix
MONGODB_URI=mongodb://localhost:27017/chatfix

# Configuración IA Asistente
# El backend se encargará de validar que la URL tenga un formato válido (http/https).
# Las URL inválidas enviadas por API (PUT /api/ai/config) devolverán un error 400.
AI_PROVIDER=lmstudio
LM_STUDIO_URL=http://127.0.0.1:1234
AI_TIMEOUT_MS=15000

STATUS_POLL_INTERVAL_MS=60000
MODEL_NAME=llama-3.1-8b-instruct

# Configuración de Cloudflare AI (Opcional, usado si AI_PROVIDER=cloudflare)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_AI_BASE_URL=

# Configuración avanzada de IA
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=180

# Configuración de Prompts de IA
AI_SYSTEM_PROMPT="Eres un corrector experto de mensajes de WhatsApp en español. Corrige ortografía, gramática y claridad manteniendo el tono y la intención original. No incluyas razonamiento interno ni etiquetas como <think>."
AI_USER_PROMPT_TEMPLATE="Corregí este texto y devolvé solo la versión final corregida, sin explicación:\n\n{{text}}"

# ==============================================================
# CACHÉ Y LÍMITES
# ==============================================================
CHATS_CACHE_TTL_MS=5000
MESSAGES_CACHE_TTL_MS=5000
AVATAR_TTL_MS=600000
AVATAR_FETCH_LIMIT=40
AVATAR_FETCH_TIMEOUT_MS=7000

# ==============================================================
# PROVEEDORES Y CUENTAS
# ==============================================================
DEFAULT_ACCOUNT_ID=default
CHROME_EXECUTABLE_PATH=/usr/bin/google-chrome

# ==============================================================
# SEGURIDAD Y AUTENTICACIÓN
# ==============================================================

# Defíne tu propia clave secreta usada para acceder al WebPanel 
# (Y a todas las peticiones desde el panel a la API)
# Si lo dejas vacío, la aplicación no pedirá contraseña para entrar.
# ADVERTENCIA: Debes cambiar este valor en producción por uno de al menos 8 caracteres.
API_KEY=

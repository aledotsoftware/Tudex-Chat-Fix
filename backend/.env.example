# -------------------------------------------------------------
# ENV VARIABLES FOR CHATFIX BACKEND
# -------------------------------------------------------------

# Puerto donde corre el servidor de la API
PORT=3005

# Cadena de conexión para MongoDB (Local o en Docker)
# Ejemplo local: mongodb://localhost:27017/chatfix
# Ejemplo docker: mongodb://mongo:27017/chatfix
MONGODB_URI=mongodb://localhost:27017/chatfix

# Configuración IA Asistente
# El backend se encargará de validar proactivamente que las URLs (LM_STUDIO_URL, CLOUDFLARE_AI_BASE_URL)
# tengan un formato válido (http o https) independientemente del proveedor activo. Valores inválidos en arranque fallan a un default
# (LM_STUDIO_URL por defecto a 'http://localhost:1234', CLOUDFLARE_AI_BASE_URL por defecto a vacío)
# y emiten warnings sin duplicados; en API (PUT /api/ai/config) devuelven un error 400 Bad Request.
# Además, la clave API_KEY, MODEL_NAME, y las opciones de CLOUDFLARE_* se validan
# en el arranque para emitir advertencias de configuración faltante o de severa inseguridad.
#
# Los tiempos de expiración, límites operativos y configuraciones avanzadas
# son validados de manera estricta mediante la utilidad "safeNumber". Si exceden sus
# rangos permitidos, se registrará una advertencia y el valor se ajustará automáticamente (clamp) a los límites:
# - STATUS_POLL_INTERVAL_MS: min=1000, max=86400000, default=60000
# - AI_TIMEOUT_MS: min=1000, max=60000, default=15000
# - AI_TEMPERATURE: min=0, max=2, default=0.7
# - AI_MAX_TOKENS: min=1, max=8192, default=180
# - AVATAR_TTL_MS: min=1000, max=86400000, default=600000
# - AVATAR_FETCH_LIMIT: min=1, max=200, default=40
# - AVATAR_FETCH_TIMEOUT_MS: min=1000, max=30000, default=7000
# - CHATS_CACHE_TTL_MS: min=0, max=3600000, default=5000
# - MESSAGES_CACHE_TTL_MS: min=0, max=3600000, default=5000
AI_PROVIDER=lmstudio
LM_STUDIO_URL=http://127.0.0.1:1234
AI_TIMEOUT_MS=15000

STATUS_POLL_INTERVAL_MS=60000
MODEL_NAME=llama-3.1-8b-instruct

# Configuración de Cloudflare AI (Opcional, usado si AI_PROVIDER=cloudflare)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_AI_BASE_URL=

# Configuración avanzada de IA
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=180

# Configuración de Prompts de IA
AI_SYSTEM_PROMPT="Eres un corrector experto de mensajes de WhatsApp en español. Corrige ortografía, gramática y claridad manteniendo el tono y la intención original. No incluyas razonamiento interno ni etiquetas como <think>."
AI_USER_PROMPT_TEMPLATE="Corregí este texto y devolvé solo la versión final corregida, sin explicación:\n\n{{text}}"

# ==============================================================
# CACHÉ Y LÍMITES
# ==============================================================
CHATS_CACHE_TTL_MS=5000
MESSAGES_CACHE_TTL_MS=5000
AVATAR_TTL_MS=600000
AVATAR_FETCH_LIMIT=40
AVATAR_FETCH_TIMEOUT_MS=7000

# ==============================================================
# PROVEEDORES Y CUENTAS
# ==============================================================
DEFAULT_ACCOUNT_ID=default
CHROME_EXECUTABLE_PATH=/usr/bin/google-chrome-stable

# ==============================================================
# SEGURIDAD Y AUTENTICACIÓN
# ==============================================================

# Define tu propia clave secreta usada para acceder al WebPanel
# (Y a todas las peticiones desde el panel a la API).
# Si lo dejas vacío, la aplicación no pedirá contraseña para entrar y registrará un warning de seguridad.
# ADVERTENCIA: Debes cambiar este valor en producción por uno de al menos 8 caracteres para considerarse seguro.
API_KEY=

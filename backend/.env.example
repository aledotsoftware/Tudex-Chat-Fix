# -------------------------------------------------------------
# ENV VARIABLES FOR CHATFIX BACKEND
# -------------------------------------------------------------

# Puerto donde corre el servidor de la API
PORT=3005

# Cadena de conexión para MongoDB (Local o en Docker)
# Ejemplo local: mongodb://localhost:27017/chatfix
# Ejemplo docker: mongodb://mongo:27017/chatfix
MONGODB_URI=mongodb://localhost:27017/chatfix

# Configuración IA Asistente (Opcional - Reemplazar por lo de LM Studio u otra API compatible)
# El backend se encargará de validar que la URL tenga un formato válido.
LM_STUDIO_URL=http://127.0.0.1:1234
AI_TIMEOUT_MS=15000
STATUS_POLL_INTERVAL_MS=60000
MODEL_NAME=llama-3.1-8b-instruct

# ==============================================================
# SEGURIDAD Y AUTENTICACIÓN
# ==============================================================

# Defíne tu propia clave secreta usada para acceder al WebPanel 
# (Y a todas las peticiones desde el panel a la API)
# Si lo dejas vacío, la aplicación no pedirá contraseña para entrar.
# ADVERTENCIA: Debes cambiar este valor en producción por uno de al menos 8 caracteres.
API_KEY=tu_contraseña_super_segura_aqui
